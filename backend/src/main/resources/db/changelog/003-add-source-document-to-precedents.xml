<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-add-source-document-to-precedents" author="legal-analysis">
        <addColumn tableName="precedents">
            <column name="source_document_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
                constraintName="fk_precedents_source_document"
                baseTableName="precedents"
                baseColumnNames="source_document_id"
                referencedTableName="documents"
                referencedColumnNames="id"/>

        <addUniqueConstraint
                constraintName="uk_precedents_source_document"
                tableName="precedents"
                columnNames="source_document_id"/>
    </changeSet>

</databaseChangeLog>
