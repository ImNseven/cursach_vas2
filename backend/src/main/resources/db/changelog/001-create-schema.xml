<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-roles" author="legal-analysis">
        <createTable tableName="roles">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="002-create-users" author="legal-analysis">
        <createTable tableName="users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)"/>
            <column name="full_name" type="VARCHAR(255)"/>
            <column name="github_id" type="VARCHAR(100)"/>
            <column name="avatar_url" type="VARCHAR(500)"/>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_users_role"
                             references="roles(id)"/>
            </column>
            <column name="refresh_token" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex tableName="users" indexName="idx_users_email">
            <column name="email"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-categories" author="legal-analysis">
        <createTable tableName="categories">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="parent_id" type="BIGINT">
                <constraints foreignKeyName="fk_categories_parent" references="categories(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-tags" author="legal-analysis">
        <createTable tableName="tags">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="color" type="VARCHAR(20)"/>
        </createTable>
    </changeSet>

    <changeSet id="005-create-documents" author="legal-analysis">
        <createTable tableName="documents">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT"/>
            <column name="file_name" type="VARCHAR(255)"/>
            <column name="file_type" type="VARCHAR(10)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_documents_user" references="users(id)"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_documents_category" references="categories(id)"/>
            </column>
            <column name="similarity_threshold" type="FLOAT" defaultValueNumeric="0.3"/>
            <column name="is_analyzed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="uploaded_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="documents" indexName="idx_documents_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="006-create-document-tags" author="legal-analysis">
        <createTable tableName="document_tags">
            <column name="document_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_doc_tags_document" references="documents(id)"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_doc_tags_tag" references="tags(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="document_tags" columnNames="document_id,tag_id"/>
    </changeSet>

    <changeSet id="007-create-precedents" author="legal-analysis">
        <createTable tableName="precedents">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_number" type="VARCHAR(100)">
                <constraints unique="true"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT"/>
            <column name="summary" type="TEXT"/>
            <column name="decision_date" type="DATE"/>
            <column name="court_name" type="VARCHAR(300)"/>
            <column name="decision" type="VARCHAR(100)"/>
            <column name="category_id" type="BIGINT">
                <constraints foreignKeyName="fk_precedents_category" references="categories(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="precedents" indexName="idx_precedents_category">
            <column name="category_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="008-create-precedent-tags" author="legal-analysis">
        <createTable tableName="precedent_tags">
            <column name="precedent_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_prec_tags_precedent" references="precedents(id)"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_prec_tags_tag" references="tags(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="precedent_tags" columnNames="precedent_id,tag_id"/>
    </changeSet>

    <changeSet id="009-create-document-precedents" author="legal-analysis">
        <createTable tableName="document_precedents">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_dp_document" references="documents(id)"/>
            </column>
            <column name="precedent_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_dp_precedent" references="precedents(id)"/>
            </column>
            <column name="similarity_score" type="FLOAT">
                <constraints nullable="false"/>
            </column>
            <column name="matched_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="document_precedents" indexName="idx_dp_document">
            <column name="document_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="010-create-search-history" author="legal-analysis">
        <createTable tableName="search_history">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_search_user" references="users(id)"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints foreignKeyName="fk_search_document" references="documents(id)"/>
            </column>
            <column name="results_count" type="INTEGER"/>
            <column name="searched_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="search_history" indexName="idx_search_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="011-create-favorites" author="legal-analysis">
        <createTable tableName="favorites">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_fav_user" references="users(id)"/>
            </column>
            <column name="precedent_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_fav_precedent" references="precedents(id)"/>
            </column>
            <column name="added_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="favorites" columnNames="user_id,precedent_id"/>
    </changeSet>

    <changeSet id="012-create-annotations" author="legal-analysis">
        <createTable tableName="annotations">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ann_document" references="documents(id)"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ann_user" references="users(id)"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="start_position" type="INTEGER"/>
            <column name="end_position" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
