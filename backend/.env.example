# Скопируй этот файл в backend/.env и заполни своими значениями.
# backend/.env в git не коммитится.

# --- База данных (локальная PostgreSQL) ---
# Если порт стандартный (5432) — так и оставь.
# Если твоя PostgreSQL слушает другой порт — поменяй.
DATABASE_URL=jdbc:postgresql://localhost:5432/legal_analysis?sslmode=disable
DB_USERNAME=postgres
DB_PASSWORD=твой_пароль_от_postgres

# --- JWT ---
# Любая длинная случайная строка (минимум 32 символа hex)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=Iv23litDJyhMjHkL1oDL
GITHUB_CLIENT_SECRET=1b3e92bf99096099fdbd2dd80f2808b8de374d0f

